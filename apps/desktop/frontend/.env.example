# explorie Desktop - Environment Variables
# Copy this file to .env.local for local development overrides
# All VITE_* variables are exposed to the frontend at build time

# =============================================================================
# Development Server
# =============================================================================

# Vite dev server port (default: 5173)
# Note: Also update tauri.conf.json devUrl if changing this
VITE_DEV_PORT=5173

# Fail if port is in use (default: true)
# Set to 'false' to allow Vite to find an available port
VITE_STRICT_PORT=true

# =============================================================================
# Build Options
# =============================================================================

# Enable source maps in production build (default: false)
# Set to 'true' for debugging production builds
VITE_SOURCEMAP=false

# Strip console.log and debugger statements (default: true in production)
# Set to 'false' to keep console statements in production
VITE_DROP_CONSOLE=true

# Enable bundle analyzer (alternative to ANALYZE=1)
ANALYZE=0

# =============================================================================
# Rust Backend (set in terminal, not .env)
# =============================================================================

# Rust log level filter (controls backend logging verbosity)
# Examples:
#   RUST_LOG=info
#   RUST_LOG=debug
#   RUST_LOG=explorie_core=debug,info
#   RUST_LOG=warn
# Default: info,explorie_core=debug
# RUST_LOG=info,explorie_core=debug

# =============================================================================
# CI/Build Environment
# =============================================================================

# Force specific Cargo color output
# CARGO_TERM_COLOR=always
