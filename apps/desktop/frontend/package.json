{
  "name": "explorie-desktop",
  "version": "0.2.4",
  "private": true,
  "description": "explorie desktop app (Tauri + React)",
  "scripts": {
    "dev": "vite",
    "prepare:rclone": "node ../../../scripts/prepare-rclone.mjs",
    "prepare:winfsp": "node ../../../scripts/prepare-winfsp.mjs",
    "prepare:native": "pnpm run prepare:rclone && pnpm run prepare:winfsp",
    "tauri:dev": "tauri dev",
    "tauri:dev:watch": "tauri dev --no-watch -- -- --watch",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "tauri:build": "tauri build",
    "analyze": "ANALYZE=1 vite build",
    "tauri:icon": "tauri icon ./public/icon.png -o ./src-tauri/icons"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.6",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@tanstack/react-virtual": "^3.10.4",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/cli": "^2.11.4",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "jsdom": "^24.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rollup-plugin-visualizer": "^5.12.0",
    "typescript": "^5.7.2",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "pixelarticons": "1.8.0",
    "zustand": "^5.0.3"
  }
}
