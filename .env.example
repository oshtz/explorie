# explorie Monorepo - Environment Variables
# Copy this file to .env.local for local development overrides

# =============================================================================
# Rust Configuration
# =============================================================================

# Rust log level filter (controls backend logging verbosity)
# Examples:
#   RUST_LOG=info                          # General info level
#   RUST_LOG=debug                         # Debug all crates
#   RUST_LOG=explorie_core=debug,info      # Debug core crate, info for others
#   RUST_LOG=warn                          # Warnings and errors only
#   RUST_LOG=explorie_core=trace           # Trace level for core crate
# Default: info,explorie_core=debug
RUST_LOG=info,explorie_core=debug

# Cargo output colors (useful in CI)
CARGO_TERM_COLOR=always

# =============================================================================
# Frontend Configuration
# =============================================================================
# See apps/desktop/frontend/.env.example for frontend-specific variables

# =============================================================================
# Development Tools
# =============================================================================

# Node.js version (see engines in package.json)
# Recommended: 20.x LTS

# pnpm version (see engines in package.json)
# Recommended: 9.x

# Required system dependencies:
# - FFmpeg: For video thumbnail generation (ffprobe)
#   Windows: winget install ffmpeg / choco install ffmpeg
#   macOS: brew install ffmpeg
#
# - cargo-watch: For Rust hot reload during development
#   Install: cargo install cargo-watch
#   Usage: pnpm rust:watch
#
# - Rust toolchain: stable channel
#   Install: rustup default stable
